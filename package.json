{
  "name": "auth-lab",
  "private": true,
  "packageManager": "yarn@4.12.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "./scripts/dev.sh",
    "dev:stack": "./scripts/dev.sh --stack",
    "stack": "./scripts/stack.sh up",
    "stack:down": "./scripts/stack.sh down",
    "stack:test": "./scripts/stack.sh test",
    "stop": "./scripts/stop.sh",
    "status": "./scripts/status.sh",
    "reset-db": "./scripts/reset-db.sh",
    "fmt": "prettier . --write",
    "fmt:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:backend": "eslint backend",
    "lint:frontend": "eslint frontend",
    "typecheck": "yarn typecheck:backend && yarn typecheck:frontend",
    "typecheck:backend": "yarn workspace @auth-lab/backend typecheck",
    "typecheck:frontend": "yarn workspace frontend typecheck",
    "build:frontend": "yarn workspace frontend build",
    "test": "./scripts/test.sh",
    "test:backend": "yarn workspace @auth-lab/backend test",
    "test:frontend:unit": "yarn workspace frontend test:unit",
    "test:e2e": "yarn workspace frontend test:e2e",
    "test:watch": "yarn workspace @auth-lab/backend test:watch",
    "verify": "./scripts/verify.sh",
    "seed:dev": "yarn workspace @auth-lab/backend db:seed:dev",
    "seed:e2e": "yarn workspace @auth-lab/backend db:seed:e2e",
    "bootstrap:tenant": "yarn workspace @auth-lab/backend db:bootstrap:tenant",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.0.0"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{js,mjs,cjs,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "concurrently": "^9.2.1"
  },
  "resolutions": {
    "picomatch@npm:^2.3.1": "npm:2.3.2",
    "picomatch@npm:^4.0.3": "npm:4.0.4"
  }
}
