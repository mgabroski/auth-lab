# infra/.env.example
#
# Minimal vars for infra-only compose (docker-compose-infra.yml).
# These are already set as defaults in docker-compose.yml.
# Copy this only if you need to override them.

POSTGRES_DB=auth_lab
POSTGRES_USER=auth_lab
POSTGRES_PASSWORD=auth_lab
POSTGRES_PORT=5432

REDIS_PORT=6379