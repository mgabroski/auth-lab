# infra/.env.example
#
# WHY:
# - Documents variables for the full Docker topology stack (scripts/stack.sh).
# - Safe to commit: dev-only values, no real secrets.
#
# HOW TO USE:
#   cp infra/.env.example infra/.env
#
# NOTE: docker-compose.yml sets these values directly as defaults.
# Copy this file only if you need to override them.

# Postgres
POSTGRES_DB=auth_lab
POSTGRES_USER=auth_lab
POSTGRES_PASSWORD=auth_lab
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Next.js SSR internal API URL (container-to-container in Docker stack)
# WHY: Server Components call the backend directly, bypassing Caddy.
# This is set in docker-compose.yml under frontend.environment.
# In host-run mode, the equivalent is frontend/.env.local INTERNAL_API_URL=http://localhost:3001
INTERNAL_API_URL=http://backend:3001