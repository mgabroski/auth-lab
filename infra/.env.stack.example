# infra/.env.stack.example
#
# Copy to infra/.env.stack for Docker Compose stack usage.
# Loaded by scripts/stack.sh and scripts/dev.sh via --env-file.
# DB/Redis/SMTP URLs use Docker container names (postgres, redis, mailpit).
# Keep real secrets only in infra/.env.stack or your secret manager.
# NEVER put real staging or production credentials in this file.

NODE_ENV=development
PORT=3001

POSTGRES_DB=auth_lab
POSTGRES_USER=auth_lab
POSTGRES_PASSWORD=auth_lab
DATABASE_URL=postgres://auth_lab:auth_lab@postgres:5432/auth_lab
REDIS_URL=redis://redis:6379

LOG_LEVEL=info
SERVICE_NAME=auth-lab-backend

BCRYPT_COST=12
SESSION_TTL_SECONDS=86400

# MFA
# KEY SEPARATION RULE:
# MFA_ENCRYPTION_KEY_BASE64 and OUTBOX_ENC_KEY_V1 MUST be different values.
# They encrypt different data at rest. Reusing the same key is rejected in
# production by a startup guard.
# Generate: openssl rand -base64 32
# See docs/ops/runbooks.md § "Secret Management and Environment Promotion Rules".
MFA_ISSUER=Hubins
MFA_ENCRYPTION_KEY_BASE64=N0uFFqX7KeFnhghnTMaeBdLKsn+W2Q9WJE1D2Aqdf14=
MFA_HMAC_KEY_BASE64=ygcc6Pr65aoBSF469cwcsVj+ARz1Pb2voHHHtt3bbCQ=

# SSO
# SSO_STATE_ENCRYPTION_KEY must not be all-zeros in any non-test environment.
# The server refuses to start if it detects all-zeros outside test mode.
# Generate: openssl rand -base64 32
SSO_STATE_ENCRYPTION_KEY=g+0YvJfzVdIgM+eoUUQ5UW3JKuGktJbtA6mvi3DcZDQ=
SSO_REDIRECT_BASE_URL=http://goodwill-ca.lvh.me:3000/api
# Set real values in infra/.env.stack only — never here.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# Outbox
# OUTBOX_ENC_KEY_V1 must be different from MFA_ENCRYPTION_KEY_BASE64.
OUTBOX_ENC_DEFAULT_VERSION=v1
OUTBOX_ENC_KEY_V1=pjVKt5jeXMDX5YJkbDc1dDFW4ztqO1iRyHiAHi/9TjM=
OUTBOX_POLL_INTERVAL_MS=5000
OUTBOX_BATCH_SIZE=10
OUTBOX_MAX_ATTEMPTS=5

# Email — Docker stack routes SMTP to Mailpit container
EMAIL_PROVIDER=smtp
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM=Hubins <noreply@hubins.local>
SMTP_PUBLIC_BASE_URL=http://{tenantKey}.lvh.me:3000

# Dev seed
SEED_ON_START=true
SEED_TENANT_KEY=goodwill-ca
SEED_TENANT_NAME=GoodWill California
SEED_ADMIN_EMAIL=system_admin@example.com
SEED_INVITE_TTL_HOURS=168

# Frontend / Control Plane container runtime
FRONTEND_INTERNAL_API_URL=http://backend:3001
CP_INTERNAL_API_URL=http://backend:3001
NEXT_PUBLIC_ENV=development

# ─── Local OIDC server (CI only) ─────────────────────────────────────────────
# Injected by the CI workflow alongside docker-compose-ci-oidc.yml.
# Do NOT set in staging or production.
# LOCAL_OIDC_ENABLED=true
# LOCAL_OIDC_ISSUER=http://local-oidc:9998
# LOCAL_OIDC_CLIENT_ID=local-oidc-ci-client