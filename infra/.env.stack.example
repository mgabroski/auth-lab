# infra/.env.stack.example
#
# Copy to infra/.env.stack for Docker stack / infra-only compose usage.
# This file is loaded by scripts/dev.sh and scripts/stack.sh via --env-file.
# Keep real secrets only in infra/.env.stack or your secret manager.

NODE_ENV=development
PORT=3001

POSTGRES_DB=auth_lab
POSTGRES_USER=auth_lab
POSTGRES_PASSWORD=auth_lab
DATABASE_URL=postgres://auth_lab:auth_lab@postgres:5432/auth_lab
REDIS_URL=redis://redis:6379

LOG_LEVEL=info
SERVICE_NAME=auth-lab-backend

BCRYPT_COST=12
SESSION_TTL_SECONDS=86400

# MFA
# KEY SEPARATION RULE:
# MFA_ENCRYPTION_KEY_BASE64 and MFA_HMAC_KEY_BASE64 must be unique per environment.
# Dev and CI may share the example values below — dev data is ephemeral.
# Staging and production MUST use independently generated keys from a secret manager.
# NEVER commit real staging or production keys to any file.
# Generate a fresh key: openssl rand -base64 32
# See docs/ops/runbooks.md § "Secret Management and Environment Promotion Rules".
MFA_ISSUER=Hubins
MFA_ENCRYPTION_KEY_BASE64=VjJlYds7lPHtOzCrEQNNR0O7Ukst5HzX+cnszDyXvq0=
MFA_HMAC_KEY_BASE64=8Emt6e4gn6r8rgRGSuYTVQ+D/3upFEckXRoMQYKJRJ8=

# SSO
SSO_STATE_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
SSO_REDIRECT_BASE_URL=http://goodwill-ca.lvh.me:3000/api
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# Outbox
OUTBOX_ENC_DEFAULT_VERSION=v1
OUTBOX_ENC_KEY_V1=Kj3mN8vP2qR5sT7wX1yZ4aB6cD9eF0gH3iJ5kL7mN9=
OUTBOX_POLL_INTERVAL_MS=5000
OUTBOX_BATCH_SIZE=10
OUTBOX_MAX_ATTEMPTS=5

# Email (Docker stack routes SMTP to Mailpit)
EMAIL_PROVIDER=smtp
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM=Hubins <noreply@hubins.local>
SMTP_PUBLIC_BASE_URL=http://{tenantKey}.lvh.me:3000

# Dev seed
SEED_ON_START=true
SEED_TENANT_KEY=goodwill-ca
SEED_TENANT_NAME=GoodWill California
SEED_ADMIN_EMAIL=system_admin@example.com
SEED_INVITE_TTL_HOURS=168

# Frontend container runtime
FRONTEND_INTERNAL_API_URL=http://backend:3001
NEXT_PUBLIC_ENV=development

# ─── Local OIDC server (CI only — Phase 6/7 SSO proof) ──────────────────────
# These vars are injected by the CI workflow when using docker-compose-ci-oidc.yml.
# They must NEVER be set in staging or production.
# See infra/docker-compose-ci-oidc.yml and docs/ops/runbooks.md.
#
# LOCAL_OIDC_ENABLED=true
# LOCAL_OIDC_ISSUER=http://local-oidc:9998
# LOCAL_OIDC_CLIENT_ID=local-oidc-ci-client