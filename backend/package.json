{
  "name": "@auth-lab/backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start:container": "tsx src/index.ts",
    "db:make": "tsx src/shared/db/make-migration.ts",
    "db:migrate": "tsx src/shared/db/migrate.ts",
    "db:types": "tsx src/shared/db/codegen.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "db:seed:dev": "tsx src/shared/db/seed/run-dev-seed.ts",
    "db:bootstrap:tenant": "tsx src/shared/db/seed/run-bootstrap-tenant.ts",
    "db:seed:e2e": "tsx src/shared/db/seed/run-seed-e2e-fixtures.ts",
    "typecheck:tests": "tsc -p tsconfig.tests.json"
  },
  "dependencies": {
    "@sentry/node": "^10.42.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.7.2",
    "jose": "^6.1.3",
    "kysely": "^0.28.14",
    "nodemailer": "^7.0.11",
    "otpauth": "^9.5.0",
    "pg": "^8.13.1",
    "redis": "^5.10.0",
    "winston": "^3.14.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20.11.30",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.11.10",
    "kysely-codegen": "0.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.4.5",
    "vitest": "^2.1.0"
  }
}
