# backend/.env.example
#
# Copy to backend/.env for local host-run development.
# Keep real secrets only in backend/.env or your secret manager.
# NEVER put real staging or production credentials in this file.

NODE_ENV=development
PORT=3001

DATABASE_URL=postgres://auth_lab:auth_lab@localhost:5432/auth_lab
REDIS_URL=redis://localhost:6379

LOG_LEVEL=info
SERVICE_NAME=auth-lab-backend

BCRYPT_COST=12

# COOKIE SECURITY NOTE
# Session cookies use the Secure flag only when NODE_ENV=production.
# Any shared or internet-facing environment must set NODE_ENV=production.
# Local HTTP development (lvh.me) must use NODE_ENV=development.
# Never deploy to a shared environment with NODE_ENV=development.
SESSION_TTL_SECONDS=86400

# KEY SEPARATION — MFA encryption keys must never be shared between environments.
# Each environment (dev / staging / production) must use a distinct 32-byte base64 key.
# Sharing the dev key with staging means an MFA secret encrypted in dev is
# importable to staging. Generate a unique key per environment:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Re-evaluation trigger: MFA_PER_TENANT_TRIGGER (see docs/decision-log.md ADR-010).

# MFA
# KEY SEPARATION RULE:
# MFA_ENCRYPTION_KEY_BASE64 and OUTBOX_ENC_KEY_V1 MUST be different values —
# even in dev. They encrypt different data at rest. Reusing the same key for
# both is rejected in production by a startup guard.
# Generate a fresh key: openssl rand -base64 32
# See docs/ops/runbooks.md § "Pre-Staging and Pre-Production Security Checklist".
MFA_ISSUER=Hubins
MFA_ENCRYPTION_KEY_BASE64=N0uFFqX7KeFnhghnTMaeBdLKsn+W2Q9WJE1D2Aqdf14=
MFA_HMAC_KEY_BASE64=ygcc6Pr65aoBSF469cwcsVj+ARz1Pb2voHHHtt3bbCQ=

# KEY SEPARATION — SSO state encryption key must be unique per environment.
# The dev key (all-zeros) is a deliberate placeholder — it is not secret and
# must NEVER be used in staging or production.
# Generate a unique key:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# The OUTBOX_ENC_KEY_V1 and MFA_ENCRYPTION_KEY_BASE64 must also differ per environment.

# Control Plane
# CP is a permanent internal app surface. CP_ENABLED controls route registration.
# CP_AUTH_MODE=none is a local/CI-only bridge while dedicated CP auth is deferred.
# Production must never run with CP_AUTH_MODE=none.
CP_ENABLED=true
CP_AUTH_MODE=none
# Deprecated compatibility alias. Leave unset for new environments.
# CP_NO_AUTH_ALLOWED=true

# SSO
# SSO_STATE_ENCRYPTION_KEY must not be all-zeros in any non-test environment.
# The server refuses to start if it detects the all-zeros placeholder outside test mode.
# Generate: openssl rand -base64 32
SSO_STATE_ENCRYPTION_KEY=g+0YvJfzVdIgM+eoUUQ5UW3JKuGktJbtA6mvi3DcZDQ=
SSO_REDIRECT_BASE_URL=http://goodwill-ca.lvh.me:3000/api
# Set real OAuth credentials in backend/.env only — never here.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# Outbox
# OUTBOX_ENC_KEY_V1 must be different from MFA_ENCRYPTION_KEY_BASE64.
OUTBOX_ENC_DEFAULT_VERSION=v1
OUTBOX_ENC_KEY_V1=pjVKt5jeXMDX5YJkbDc1dDFW4ztqO1iRyHiAHi/9TjM=
OUTBOX_POLL_INTERVAL_MS=5000
OUTBOX_BATCH_SIZE=10
OUTBOX_MAX_ATTEMPTS=5

# Email (host-run mode talks to local Mailpit on localhost)
EMAIL_PROVIDER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM=Hubins <noreply@hubins.local>
SMTP_PUBLIC_BASE_URL=http://{tenantKey}.lvh.me:3000

# Dev seed
SEED_ON_START=true
SEED_TENANT_KEY=goodwill-ca
SEED_TENANT_NAME=GoodWill California
SEED_ADMIN_EMAIL=system_admin@example.com
SEED_INVITE_TTL_HOURS=168

# Local OIDC server (dev + CI — started automatically by docker-compose-infra.yml)
# WHY: Enables LocalOidcSsoAdapter so Playwright SSO callback tests (tests 8 + 9)
# prove the real jose jwtVerify() cryptographic path without real OAuth credentials.
# ISSUER is localhost:9998 in host-run mode (backend on host, OIDC container
# exposes port 9998). In Docker stack mode infra/.env.stack overrides this to
# http://local-oidc:9998 (Docker-internal DNS between containers).
# Safe to commit: these are dev/CI-only values, never used in production.
LOCAL_OIDC_ENABLED=true
LOCAL_OIDC_ISSUER=http://localhost:9998
LOCAL_OIDC_CLIENT_ID=local-oidc-ci-client