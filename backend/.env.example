# backend/.env.example
#
# DEV-ONLY example environment for host-run mode.
# scripts/dev.sh copies this to backend/.env if backend/.env does not exist.
#
# Host-run topology:
# - backend runs on host at localhost:3001
# - Postgres and Redis run in Docker and expose localhost ports
# - frontend runs on host at goodwill-ca.localhost:3000

NODE_ENV=development
PORT=3001

DATABASE_URL=postgres://auth_lab:auth_lab@localhost:5432/auth_lab
REDIS_URL=redis://localhost:6379

LOG_LEVEL=info
SERVICE_NAME=auth-lab-backend

BCRYPT_COST=12
SESSION_TTL_SECONDS=86400

MFA_ISSUER=Hubins
MFA_ENCRYPTION_KEY_BASE64=VjJlYds7lPHtOzCrEQNNR0O7Ukst5HzX+cnszDyXvq0=
MFA_HMAC_KEY_BASE64=8Emt6e4gn6r8rgRGSuYTVQ+D/3upFEckXRoMQYKJRJ8=

# DEV ONLY — example keys safe for local development
SSO_STATE_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Fallback only: startSso prefers the real request public origin.
# Keep this aligned with the host-run tenant-aware browser URL.
SSO_REDIRECT_BASE_URL=http://goodwill-ca.localhost:3000/api

GOOGLE_CLIENT_ID=test-google-client-id
GOOGLE_CLIENT_SECRET=test-google-client-secret
MICROSOFT_CLIENT_ID=test-microsoft-client-id
MICROSOFT_CLIENT_SECRET=test-microsoft-client-secret

OUTBOX_POLL_INTERVAL_MS=5000
OUTBOX_BATCH_SIZE=10
OUTBOX_MAX_ATTEMPTS=5

OUTBOX_ENC_DEFAULT_VERSION=v1
OUTBOX_ENC_KEY_V1=VjJlYds7lPHtOzCrEQNNR0O7Ukst5HzX+cnszDyXvq0=

SEED_ON_START=true
SEED_TENANT_KEY=goodwill-ca
SEED_TENANT_NAME=GoodWill California
SEED_ADMIN_EMAIL=system_admin@example.com
SEED_INVITE_TTL_HOURS=168

# Optional in dev; leave unset unless you want local Sentry capture
# SENTRY_DSN=