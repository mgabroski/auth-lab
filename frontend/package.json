{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src test --ext .ts,.tsx,.js,.mjs",
    "lint:fix": "eslint src test --ext .ts,.tsx,.js,.mjs --fix",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run --config vitest.config.mts",
    "test:unit:watch": "vitest --config vitest.config.mts",
    "test:e2e": "playwright test test/e2e/auth.spec.ts",
    "test:e2e:auth": "playwright test test/e2e/auth.spec.ts",
    "test:e2e:cp": "playwright test test/e2e/cp-smoke.spec.ts",
    "test:e2e:all": "playwright test",
    "test": "yarn test:unit"
  },
  "dependencies": {
    "next": "^15.5.12",
    "react": "^18",
    "react-dom": "^18",
    "react-qr-code": "^2.0.18",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "typescript": "^5",
    "vitest": "^2.1.0"
  }
}
