# frontend/.env.example
#
# DEV-ONLY example environment for host-run mode.
# scripts/dev.sh copies this to frontend/.env.local if it does not exist.
#
# IMPORTANT:
# - Browser code still uses same-origin /api/*
# - This INTERNAL_API_URL is for SSR and the host-run Route Handler proxy only

INTERNAL_API_URL=http://localhost:3001
NEXT_PUBLIC_ENV=development